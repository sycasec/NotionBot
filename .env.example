# Required
DISCORD_TOKEN=
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=

# LLM provider: "ollama" (default) or "groq"
LLM_PROVIDER=ollama

# Ollama settings (only needed if LLM_PROVIDER=ollama)
OLLAMA_MODEL=qwen2.5:14b

# Groq settings (only needed if LLM_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Logging: DEBUG, INFO (default), WARNING, ERROR
LOG_LEVEL=INFO
